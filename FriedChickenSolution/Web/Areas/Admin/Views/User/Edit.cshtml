@model UserAdminEditViewModel
@{
    ViewData["Title"] = "Sửa thông tin người dùng";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="User" asp-action="Index" class="btn btn-outline-secondary rounded-pill">
        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
    </a>
    <h2 class="section-title mb-0">Sửa người dùng: @Model.Username</h2>
</div>

<div class="admin-card p-4" style="max-width: 550px;">
    <form asp-area="Admin" asp-controller="User" asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input asp-for="Username" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Tên đăng nhập</label>
            <input value="@Model.Username" class="form-control" readonly />
        </div>

        <div class="mb-3">
            <label asp-for="FullName" class="form-label fw-semibold">Họ và tên</label>
            <input asp-for="FullName" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Phone" class="form-label fw-semibold">Số điện thoại</label>
            <input asp-for="Phone" class="form-control" />
            <span asp-validation-for="Phone" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Email" class="form-label fw-semibold">Email</label>
            <input asp-for="Email" class="form-control" type="email" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary rounded-pill px-4">
                <i class="fa-solid fa-save me-2"></i>Lưu thay đổi
            </button>
            <a asp-area="Admin" asp-controller="User" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
