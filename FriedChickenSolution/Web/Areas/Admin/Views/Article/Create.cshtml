@model ArticleAdminEditViewModel
@{
    ViewData["Title"] = "Thêm bài viết";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="Article" asp-action="Index" class="btn btn-outline-secondary rounded-pill">
        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
    </a>
    <h2 class="section-title mb-0">Thêm bài viết mới</h2>
</div>

<div class="admin-card p-4">
    <form asp-area="Admin" asp-controller="Article" asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label fw-semibold">Tiêu đề <span class="text-danger">*</span></label>
            <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề bài viết" />
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Category" class="form-label fw-semibold">Danh mục <span class="text-danger">*</span></label>
            <select asp-for="Category" class="form-select">
                <option value="">-- Chọn danh mục --</option>
                <option value="Tin tức">Tin tức</option>
                <option value="Khuyến mãi">Khuyến mãi</option>
                <option value="Mẹo hay">Mẹo hay</option>
                <option value="Công thức">Công thức</option>
                <option value="Sự kiện">Sự kiện</option>
            </select>
            <span asp-validation-for="Category" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ImageFile" class="form-label fw-semibold">Ảnh bài viết</label>
            <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
            <small class="text-muted">Hoặc để trống nếu dùng URL ảnh ngoài.</small>
        </div>

        <div class="mb-4">
            <label asp-for="Content" class="form-label fw-semibold">Nội dung <span class="text-danger">*</span></label>
            <textarea asp-for="Content" class="form-control" rows="8" placeholder="Nội dung bài viết..."></textarea>
            <span asp-validation-for="Content" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary rounded-pill px-4">
                <i class="fa-solid fa-save me-2"></i>Đăng bài
            </button>
            <a asp-area="Admin" asp-controller="Article" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
