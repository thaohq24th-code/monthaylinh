@model List<ArticleAdminListViewModel>
@{
    ViewData["Title"] = "Quản lý bài viết";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h2 class="fw-black mb-0 text-uppercase text-primary" style="font-family: 'Oswald', sans-serif; font-size:1.6rem;"><i class="fa-solid fa-pen-to-square me-2"></i>Kho Bài Đăng &amp; Tin Tức</h2>
        <p class="text-muted mb-0 small">Danh sách các bài đăng khuyến mãi và tin tức cửa hàng</p>
    </div>
    <a asp-area="Admin" asp-controller="Article" asp-action="Create" class="btn btn-warning rounded-pill px-4 py-2 fw-bold text-uppercase shadow-sm" style="font-family: 'Oswald', sans-serif; font-size:0.9rem;">
        <i class="fa-solid fa-plus me-2"></i>Tạo Bài Viết Mới
    </a>
</div>

<div class="admin-card p-4 border shadow-sm bg-white rounded-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" style="font-size:0.9rem;">
            <thead class="table-light">
                <tr class="text-uppercase font-oswald" style="font-family: 'Oswald', sans-serif; letter-spacing: 0.5px;">
                    <th style="width: 80px;">Mã số</th>
                    <th>Tiêu đề bài viết</th>
                    <th style="width: 150px;">Chủ đề</th>
                    <th style="width: 150px;">Ngày đăng</th>
                    <th style="width: 220px;" class="text-end">Công cụ</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-5">Chưa có bài viết nào trong kho dữ liệu</td></tr>
                }
                @foreach (var a in Model)
                {
                    <tr>
                        <td class="fw-bold text-secondary">#@a.Id</td>
                        <td class="fw-bold text-dark">@a.Title</td>
                        <td><span class="badge bg-danger text-white px-3 py-2 rounded-pill font-oswald text-uppercase" style="font-family: 'Oswald', sans-serif; font-size:0.75rem;">@a.Category</span></td>
                        <td class="text-muted"><small><i class="fa-regular fa-calendar me-1"></i>@a.CreatedDate.ToString("dd/MM/yyyy")</small></td>
                        <td>
                            <div class="d-flex gap-2 justify-content-end">
                                <a asp-area="Admin" asp-controller="Article" asp-action="Edit" asp-route-id="@a.Id"
                                   class="btn btn-sm btn-outline-warning rounded-pill px-3 py-1 fw-bold text-uppercase font-oswald" style="font-size: 0.75rem; font-family: 'Oswald', sans-serif;">
                                    <i class="fa-solid fa-pen-to-square me-1"></i>Sửa
                                </a>
                                <a asp-area="Admin" asp-controller="Article" asp-action="Delete" asp-route-id="@a.Id"
                                   class="btn btn-sm btn-outline-danger rounded-pill px-3 py-1 fw-bold text-uppercase font-oswald" style="font-size: 0.75rem; font-family: 'Oswald', sans-serif;">
                                    <i class="fa-solid fa-trash-can me-1"></i>Xóa
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
