@model FeedbackAdminDetailViewModel
@{
    ViewData["Title"] = "Chi tiết phản hồi";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="Feedback" asp-action="Index" class="btn btn-outline-secondary rounded-pill">
        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
    </a>
    <h2 class="section-title mb-0">Chi tiết phản hồi #@Model.Id</h2>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="admin-card p-4 mb-4">
            <h5 class="fw-bold mb-3">Phản hồi của khách hàng</h5>
            <dl class="row mb-3">
                <dt class="col-sm-3">Khách hàng</dt>
                <dd class="col-sm-9 fw-bold">@(Model.Username ?? "Khách vãng lai")</dd>
                <dt class="col-sm-3">Chủ đề</dt>
                <dd class="col-sm-9">@Model.Title</dd>
                <dt class="col-sm-3">Ngày gửi</dt>
                <dd class="col-sm-9">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</dd>
            </dl>
            <div class="bg-light rounded p-3">
                <p class="mb-0">@Model.Content</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.AdminReply))
        {
            <div class="admin-card p-4">
                <h5 class="fw-bold mb-3 text-success">
                    <i class="fa-solid fa-reply me-2"></i>Phản hồi của Admin
                </h5>
                <p class="text-muted small mb-2">@Model.ReplyDate?.ToString("dd/MM/yyyy HH:mm")</p>
                <div class="bg-success bg-opacity-10 rounded p-3">
                    <p class="mb-0">@Model.AdminReply</p>
                </div>
            </div>
        }
    </div>
    <div class="col-md-4">
        <div class="admin-card p-4">
            <h5 class="fw-bold mb-3">Hành động</h5>
            <div class="d-grid gap-2">
                <a asp-area="Admin" asp-controller="Feedback" asp-action="Reply" asp-route-id="@Model.Id"
                   class="btn btn-success rounded-pill">
                    <i class="fa-solid fa-reply me-2"></i>
                    @(string.IsNullOrWhiteSpace(Model.AdminReply) ? "Trả lời" : "Sửa trả lời")
                </a>
                <form asp-area="Admin" asp-controller="Feedback" asp-action="Delete" asp-route-id="@Model.Id"
                      method="post" onsubmit="return confirm('Xóa phản hồi này?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger rounded-pill w-100">
                        <i class="fa-solid fa-trash me-2"></i>Xóa phản hồi
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
