@model FeedbackAdminReplyViewModel
@{
    ViewData["Title"] = "Trả lời phản hồi";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="Feedback" asp-action="Detail" asp-route-id="@Model.FeedbackId" class="btn btn-outline-secondary rounded-pill">
        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
    </a>
    <h2 class="section-title mb-0">Trả lời phản hồi #@Model.FeedbackId</h2>
</div>

<div class="admin-card p-4" style="max-width: 600px;">
    <form asp-area="Admin" asp-controller="Feedback" asp-action="ReplyConfirmed" asp-route-id="@Model.FeedbackId" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="FeedbackId" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="mb-4">
            <label asp-for="AdminReply" class="form-label fw-semibold fs-5">Nội dung trả lời</label>
            <textarea asp-for="AdminReply" class="form-control" rows="6" placeholder="Nhập nội dung trả lời..."></textarea>
            <span asp-validation-for="AdminReply" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success rounded-pill px-4">
                <i class="fa-solid fa-paper-plane me-2"></i>Gửi trả lời
            </button>
            <a asp-area="Admin" asp-controller="Feedback" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
