@model ProductAdminEditViewModel
@{
    ViewData["Title"] = "Sửa sản phẩm";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary rounded-pill">
        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
    </a>
    <h2 class="section-title mb-0">Sửa sản phẩm</h2>
</div>

<div class="admin-card p-4" style="max-width: 700px;">
    <form asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input asp-for="ExistingImage" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-semibold">Tên sản phẩm</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label fw-semibold">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="Price" class="form-label fw-semibold">Giá (VNĐ)</label>
                <input asp-for="Price" class="form-control" type="number" min="0" step="1000" />
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Stock" class="form-label fw-semibold">Tồn kho</label>
                <input asp-for="Stock" class="form-control" type="number" min="0" />
                <span asp-validation-for="Stock" class="text-danger small"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Type" class="form-label fw-semibold">Loại sản phẩm</label>
            <select asp-for="Type" class="form-select">
                <option value="">-- Chọn loại --</option>
                <option value="Gà rán">Gà rán</option>
                <option value="Gà quay">Gà quay</option>
                <option value="Burger">Burger</option>
                <option value="Nước uống">Nước uống</option>
                <option value="Combo">Combo</option>
            </select>
            <span asp-validation-for="Type" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Ảnh hiện tại</label>
            @if (!string.IsNullOrWhiteSpace(Model.ExistingImage))
            {
                <div class="mb-2">
                    <img src="@Model.ExistingImage" alt="Ảnh sản phẩm"
                         style="max-height: 120px; max-width: 200px; object-fit: cover; border-radius: 8px; border: 1px solid #ddd;"
                         onerror="this.src='/images/no-image.png'" />
                </div>
            }
            else
            {
                <p class="text-muted small">Chưa có ảnh</p>
            }
            <label asp-for="ImageFile" class="form-label fw-semibold">Upload ảnh mới (nếu muốn thay)</label>
            <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
            <small class="text-muted">Để trống nếu giữ nguyên ảnh cũ.</small>
        </div>

        <div class="mb-4">
            <div class="form-check form-switch">
                <input asp-for="Featured" class="form-check-input" type="checkbox" role="switch" />
                <label asp-for="Featured" class="form-check-label fw-semibold">Sản phẩm nổi bật</label>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary rounded-pill px-4">
                <i class="fa-solid fa-save me-2"></i>Cập nhật
            </button>
            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
