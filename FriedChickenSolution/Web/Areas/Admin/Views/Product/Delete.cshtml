@model ProductAdminListViewModel
@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary rounded-pill">
        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
    </a>
    <h2 class="section-title mb-0">Xác nhận xóa sản phẩm</h2>
</div>

<div class="admin-card p-4" style="max-width: 500px;">
    <div class="alert alert-danger mb-4">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>
        Bạn có chắc muốn xóa sản phẩm này không? Hành động này không thể hoàn tác.
    </div>
    <dl class="row mb-4">
        <dt class="col-sm-4">Tên sản phẩm</dt>
        <dd class="col-sm-8 fw-bold">@Model.Name</dd>
        <dt class="col-sm-4">Loại</dt>
        <dd class="col-sm-8">@Model.Type</dd>
        <dt class="col-sm-4">Giá</dt>
        <dd class="col-sm-8">@Model.Price.ToString("#,##0")đ</dd>
        <dt class="col-sm-4">Tồn kho</dt>
        <dd class="col-sm-8">@Model.Stock</dd>
    </dl>
    <form asp-area="Admin" asp-controller="Product" asp-action="DeleteConfirmed" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger rounded-pill px-4">
                <i class="fa-solid fa-trash me-2"></i>Xác nhận xóa
            </button>
            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
        </div>
    </form>
</div>
