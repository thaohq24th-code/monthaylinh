@model StaffAdminEditViewModel
@{
    ViewData["Title"] = "Sửa nhân viên";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="Staff" asp-action="Index" class="btn btn-outline-secondary rounded-pill">
        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
    </a>
    <h2 class="section-title mb-0">Sửa thông tin nhân viên</h2>
</div>

<div class="admin-card p-4" style="max-width: 600px;">
    <form asp-area="Admin" asp-controller="Staff" asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Phone" class="form-label fw-semibold">Số điện thoại</label>
            <input asp-for="Phone" class="form-control" />
            <span asp-validation-for="Phone" class="text-danger small"></span>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="Position" class="form-label fw-semibold">Chức vụ</label>
                <input asp-for="Position" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Shift" class="form-label fw-semibold">Ca làm việc</label>
                <select asp-for="Shift" class="form-select">
                    <option value="">-- Chọn ca --</option>
                    <option value="Sáng">Sáng</option>
                    <option value="Chiều">Chiều</option>
                    <option value="Tối">Tối</option>
                    <option value="Toàn thời gian">Toàn thời gian</option>
                </select>
            </div>
        </div>

        <div class="mb-4">
            <label asp-for="Salary" class="form-label fw-semibold">Lương (VNĐ)</label>
            <input asp-for="Salary" class="form-control" type="number" min="0" step="100000" />
            <span asp-validation-for="Salary" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary rounded-pill px-4">
                <i class="fa-solid fa-save me-2"></i>Cập nhật
            </button>
            <a asp-area="Admin" asp-controller="Staff" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
