@model OrderStatusUpdateViewModel
@{
    ViewData["Title"] = "Cập nhật trạng thái đơn hàng";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="Order" asp-action="Detail" asp-route-id="@Model.OrderId" class="btn btn-outline-secondary rounded-pill">
        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
    </a>
    <h2 class="section-title mb-0">Cập nhật trạng thái đơn #@Model.OrderId</h2>
</div>

<div class="admin-card p-4" style="max-width: 450px;">
    <form asp-area="Admin" asp-controller="Order" asp-action="UpdateStatusConfirmed" asp-route-id="@Model.OrderId" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="OrderId" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="mb-4">
            <label asp-for="Status" class="form-label fw-semibold fs-5">Trạng thái mới</label>
            <select asp-for="Status" class="form-select form-select-lg">
                <option value="Đang xử lý">⏳ Đang xử lý</option>
                <option value="Đang giao">🚚 Đang giao</option>
                <option value="Đã giao">✅ Đã giao</option>
                <option value="Đã hủy">❌ Đã hủy</option>
            </select>
            <span asp-validation-for="Status" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary rounded-pill px-4">
                <i class="fa-solid fa-save me-2"></i>Lưu thay đổi
            </button>
            <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
        </div>
    </form>
</div>
