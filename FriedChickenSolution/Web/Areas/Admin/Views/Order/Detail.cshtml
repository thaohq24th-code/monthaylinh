@model OrderAdminDetailViewModel
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-outline-secondary rounded-pill">
        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
    </a>
    <h2 class="section-title mb-0">Chi tiết đơn hàng #@Model.Id</h2>
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="admin-card p-4">
            <h5 class="fw-bold mb-3">Thông tin đơn hàng</h5>
            <dl class="row mb-0">
                <dt class="col-sm-5">Khách hàng</dt>
                <dd class="col-sm-7">@(Model.CustomerUsername ?? "Khách vãng lai")</dd>
                <dt class="col-sm-5">Người nhận</dt>
                <dd class="col-sm-7 fw-bold">@Model.ReceiverName</dd>
                <dt class="col-sm-5">Điện thoại</dt>
                <dd class="col-sm-7">@Model.Phone</dd>
                <dt class="col-sm-5">Địa chỉ</dt>
                <dd class="col-sm-7">@Model.Address</dd>
                <dt class="col-sm-5">Ngày đặt</dt>
                <dd class="col-sm-7">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</dd>
                <dt class="col-sm-5">Trạng thái</dt>
                <dd class="col-sm-7">
                    @{
                        var badgeClass = Model.Status switch {
                            "Đang xử lý" => "bg-warning text-dark",
                            "Đang giao" => "bg-info text-dark",
                            "Đã giao" => "bg-success",
                            "Đã hủy" => "bg-danger",
                            _ => "bg-secondary"
                        };
                    }
                    <span class="badge @badgeClass fs-6">@Model.Status</span>
                </dd>
                <dt class="col-sm-5">Tổng tiền</dt>
                <dd class="col-sm-7 fw-bold text-primary fs-5">@Model.Total.ToString("#,##0")đ</dd>
            </dl>
            <div class="mt-3">
                <a asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus" asp-route-id="@Model.Id"
                   class="btn btn-warning rounded-pill px-4">
                    <i class="fa-solid fa-pen me-2"></i>Cập nhật trạng thái
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="admin-card p-4">
            <h5 class="fw-bold mb-3">Sản phẩm trong đơn</h5>
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">SL</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.Price.ToString("#,##0")đ</td>
                                <td class="text-end fw-bold">@((item.Price * item.Quantity).ToString("#,##0"))đ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                            <td class="text-end fw-bold text-primary fs-5">@Model.Total.ToString("#,##0")đ</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
