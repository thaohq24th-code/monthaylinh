@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
<style>
.stat-card {
    background: white;
    border-radius: 1rem;
    padding: 1.5rem;
    border: none;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    transition: transform 0.2s, box-shadow 0.2s;
    overflow: hidden;
    position: relative;
}
.stat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.1); }
.stat-card-bg {
    position: absolute;
    right: -10px; top: -10px;
    font-size: 5rem;
    opacity: 0.06;
    transform: rotate(-15deg);
}
.stat-label { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #9ca3af; }
.stat-value { font-size: 1.8rem; font-weight: 800; margin: 0.25rem 0; color: #1a1f2e; }
.stat-change { font-size: 0.8rem; font-weight: 600; }
.stat-change.up { color: #10b981; }
.stat-change.down { color: #ef4444; }

.chart-card {
    background: white;
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}
.quick-action-btn {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: white;
    border: 1px solid #eef0f4;
    border-radius: 0.75rem;
    font-weight: 600;
    font-size: 0.875rem;
    color: #374151;
    text-decoration: none;
    transition: all 0.2s;
    margin-bottom: 0.5rem;
    width: 100%;
}
.quick-action-btn:hover { background: #f9fafb; border-color: var(--admin-primary, #8b5e3c); color: var(--admin-primary, #8b5e3c); transform: translateX(4px); }
.quick-action-icon {
    width: 36px; height: 36px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.9rem;
    flex-shrink: 0;
}
.status-badge {
    padding: 0.3em 0.75em;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
}
.activity-item {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #f3f4f6;
}
.activity-item:last-child { border-bottom: none; }
.activity-dot {
    width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
}
</style>
}

<!-- Báo Cáo Cửa Hàng Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-black mb-0 text-uppercase" style="font-family: 'Oswald', sans-serif; font-size:1.8rem; color: var(--admin-primary);">📊 Báo cáo hoạt động</h2>
        <p class="text-muted mb-0 small">Hệ thống quản lý Gà Rán Giòn Rụm - @DateTime.Now.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("vi-VN"))</p>
    </div>
    <div>
        <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="btn btn-warning btn-sm px-4 py-2 rounded-pill fw-bold text-uppercase" style="font-family: 'Oswald', sans-serif;">
            <i class="fa-solid fa-plus me-1"></i> Đăng món mới
        </a>
    </div>
</div>

<!-- Lối Tắt Điều Hành Nhanh (Quick Actions Horizontal Layout) -->
<h5 class="fw-bold mb-3 font-oswald text-uppercase" style="font-family: 'Oswald', sans-serif; font-size: 1.1rem; color: #64748b; letter-spacing: 1px;">⚡ Lối tắt nhanh</h5>
<div class="row g-3 mb-4">
    <div class="col-6 col-md">
        <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="quick-action-btn m-0 h-100 py-3 text-center d-flex flex-column align-items-center justify-content-center bg-white shadow-sm border rounded-4" style="transition: all 0.2s;">
            <div class="quick-action-icon mb-2" style="background:#fef3c7;color:#d97706;width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center;"><i class="fa-solid fa-hamburger"></i></div>
            <span class="small font-oswald text-uppercase text-dark" style="font-family: 'Oswald', sans-serif; font-weight:700;">Thêm Món Ăn</span>
        </a>
    </div>
    <div class="col-6 col-md">
        <a asp-area="Admin" asp-controller="Article" asp-action="Create" class="quick-action-btn m-0 h-100 py-3 text-center d-flex flex-column align-items-center justify-content-center bg-white shadow-sm border rounded-4" style="transition: all 0.2s;">
            <div class="quick-action-icon mb-2" style="background:#ede9fe;color:#7c3aed;width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center;"><i class="fa-solid fa-pen-to-square"></i></div>
            <span class="small font-oswald text-uppercase text-dark" style="font-family: 'Oswald', sans-serif; font-weight:700;">Viết Tin Tức</span>
        </a>
    </div>
    <div class="col-6 col-md">
        <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="quick-action-btn m-0 h-100 py-3 text-center d-flex flex-column align-items-center justify-content-center bg-white shadow-sm border rounded-4 position-relative" style="transition: all 0.2s;">
            <div class="quick-action-icon mb-2" style="background:#fee2e2;color:#dc2626;width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center;"><i class="fa-solid fa-receipt"></i></div>
            <span class="small font-oswald text-uppercase text-dark" style="font-family: 'Oswald', sans-serif; font-weight:700;">Xem Đặt Món</span>
            @if (Model.PendingOrders > 0)
            {
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="margin-top: 15px; margin-left: -20px;">@Model.PendingOrders</span>
            }
        </a>
    </div>
    <div class="col-6 col-md">
        <a asp-area="Admin" asp-controller="Feedback" asp-action="Index" class="quick-action-btn m-0 h-100 py-3 text-center d-flex flex-column align-items-center justify-content-center bg-white shadow-sm border rounded-4" style="transition: all 0.2s;">
            <div class="quick-action-icon mb-2" style="background:#dcfce7;color:#16a34a;width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center;"><i class="fa-solid fa-envelope-open-text"></i></div>
            <span class="small font-oswald text-uppercase text-dark" style="font-family: 'Oswald', sans-serif; font-weight:700;">Góp Ý Khách</span>
        </a>
    </div>
    <div class="col-12 col-md">
        <a asp-area="Admin" asp-controller="Settings" asp-action="Index" class="quick-action-btn m-0 h-100 py-3 text-center d-flex flex-column align-items-center justify-content-center bg-white shadow-sm border rounded-4" style="transition: all 0.2s;">
            <div class="quick-action-icon mb-2" style="background:#f0f9ff;color:#0369a1;width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center;"><i class="fa-solid fa-gear"></i></div>
            <span class="small font-oswald text-uppercase text-dark" style="font-family: 'Oswald', sans-serif; font-weight:700;">Thiết Lập</span>
        </a>
    </div>
</div>

<!-- Thống Kê Số Liệu Row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="stat-card border">
            <div class="stat-card-bg text-warning" style="opacity: 0.1;"><i class="fa-solid fa-wallet"></i></div>
            <div class="stat-label" style="font-family: 'Oswald', sans-serif; font-weight: 700; letter-spacing: 0.5px;">Tổng tiền thu về</div>
            <div class="stat-value text-warning mt-2" style="font-family: 'Oswald', sans-serif; font-weight: 900;">@(Model.TotalRevenue.ToString("N0"))đ</div>
            <div class="stat-change text-muted small mt-2"><i class="fa-solid fa-circle-info me-1"></i>Từ bán hàng</div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card border">
            <div class="stat-card-bg text-primary" style="opacity: 0.1;"><i class="fa-solid fa-utensils"></i></div>
            <div class="stat-label" style="font-family: 'Oswald', sans-serif; font-weight: 700; letter-spacing: 0.5px;">Số lượt đặt món</div>
            <div class="stat-value text-primary mt-2" style="font-family: 'Oswald', sans-serif; font-weight: 900;">@Model.TotalOrders</div>
            <div class="stat-change text-muted small mt-2"><i class="fa-solid fa-circle-check me-1"></i>Đơn hoàn thành</div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card border">
            <div class="stat-card-bg text-danger" style="opacity: 0.1;"><i class="fa-solid fa-clock"></i></div>
            <div class="stat-label" style="font-family: 'Oswald', sans-serif; font-weight: 700; letter-spacing: 0.5px;">Đơn chờ nhà bếp</div>
            <div class="stat-value text-danger mt-2" style="font-family: 'Oswald', sans-serif; font-weight: 900;">@Model.PendingOrders</div>
            <div class="stat-change text-danger small mt-2">
                <i class="fa-solid fa-circle-exclamation me-1"></i>Cần làm ngay
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card border">
            <div class="stat-card-bg text-success" style="opacity: 0.1;"><i class="fa-solid fa-address-book"></i></div>
            <div class="stat-label" style="font-family: 'Oswald', sans-serif; font-weight: 700; letter-spacing: 0.5px;">Tài khoản hội viên</div>
            <div class="stat-value text-success mt-2" style="font-family: 'Oswald', sans-serif; font-weight: 900;">@Model.TotalCustomers</div>
            <div class="stat-change text-muted small mt-2"><i class="fa-solid fa-user-check me-1"></i>Đã kích hoạt</div>
        </div>
    </div>
</div>

<!-- Lưới Dữ Liệu Chủ Đạo (Recent Orders + Summary Donut) -->
<div class="row g-3 mb-4">
    <!-- Đơn Hàng Mới Nhất -->
    <div class="col-lg-7">
        <div class="chart-card border h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="fw-bold mb-0 text-uppercase font-oswald" style="font-family: 'Oswald', sans-serif; letter-spacing: 0.5px;"><i class="fa-solid fa-list-check text-primary me-2"></i>Lượt Đặt Mới Nhất</h6>
                <a asp-controller="Order" asp-action="Index" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold small text-uppercase" style="font-size: 0.75rem;">
                    Xem Tế <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:0.875rem;">
                    <thead>
                        <tr class="table-light">
                            <th class="fw-bold border-0">Mã Số</th>
                            <th class="fw-bold border-0">Thành Viên</th>
                            <th class="fw-bold border-0">Ngày Giờ</th>
                            <th class="fw-bold border-0">Thành Tiền</th>
                            <th class="fw-bold border-0">Trạng Thái</th>
                            <th class="border-0"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.RecentOrders)
                        {
                            <tr>
                                <td class="fw-bold">#@order.Id</td>
                                <td>@order.CustomerUsername</td>
                                <td class="text-muted"><small>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</small></td>
                                <td class="fw-bold text-primary">@order.FormattedTotal</td>
                                <td>
                                    @{
                                        var (badgeBg, badgeColor) = order.Status switch {
                                            "Đang xử lý" => ("#fffbeb", "#d97706"),
                                            "Đang giao" => ("#eff6ff", "#2563eb"),
                                            "Đã giao" => ("#f0fdf4", "#16a34a"),
                                            _ => ("#f9fafb", "#6b7280")
                                        };
                                    }
                                    <span class="status-badge" style="background:@badgeBg;color:@badgeColor;">@order.Status</span>
                                </td>
                                <td>
                                    <a asp-area="Admin" asp-controller="Order" asp-action="Detail" asp-route-id="@order.Id"
                                       class="btn btn-sm btn-light rounded-pill px-3 py-1 fw-bold" style="font-size:0.75rem;">
                                        Xem Chi Tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Tóm Tắt Cơ Cấu -->
    <div class="col-lg-5">
        <div class="chart-card border h-100">
            <h6 class="fw-bold mb-4 text-uppercase font-oswald" style="font-family: 'Oswald', sans-serif; letter-spacing: 0.5px;"><i class="fa-solid fa-chart-pie text-primary me-2"></i>Tỷ Lệ Cơ Cấu Dữ Liệu</h6>
            <div class="position-relative d-flex justify-content-center align-items-center" style="height: 180px;">
                <canvas id="summaryDonut"></canvas>
            </div>
            <div class="mt-4">
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="small"><i class="fa-solid fa-hamburger text-danger me-2"></i>Tổng các Món ăn</span>
                    <span class="fw-bold small">@Model.TotalProducts</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="small"><i class="fa-solid fa-user-tag text-primary me-2"></i>Hội viên đăng ký</span>
                    <span class="fw-bold small">@Model.TotalCustomers</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2">
                    <span class="small"><i class="fa-solid fa-box text-success me-2"></i>Đơn hàng nhận được</span>
                    <span class="fw-bold small">@Model.TotalOrders</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Khối Biểu Đồ Trạng Thái (Full-Width Bottom Section) -->
<div class="row g-3">
    <div class="col-12">
        <div class="chart-card border">
            <h6 class="fw-bold mb-4 text-uppercase font-oswald" style="font-family: 'Oswald', sans-serif; letter-spacing: 0.5px;"><i class="fa-solid fa-chart-column text-primary me-2"></i>Biểu Đồ Trạng Thái Chi Tiết</h6>
            <canvas id="orderStatusChart" height="90"></canvas>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// Donut chart - Summary
const donutCtx = document.getElementById('summaryDonut').getContext('2d');
new Chart(donutCtx, {
    type: 'doughnut',
    data: {
        labels: ['Sản phẩm', 'Khách hàng', 'Đơn hàng'],
        datasets: [{
            data: [@Model.TotalProducts, @Model.TotalCustomers, @Model.TotalOrders],
            backgroundColor: ['#d32f2f', '#3b82f6', '#10b981'],
            borderWidth: 0,
            hoverOffset: 4
        }]
    },
    options: {
        responsive: true,
        cutout: '65%',
        plugins: {
            legend: { display: false }
        }
    }
});

// Bar chart - Order status
const barCtx = document.getElementById('orderStatusChart').getContext('2d');
new Chart(barCtx, {
    type: 'bar',
    data: {
        labels: ['Đang xử lý', 'Đang giao', 'Đã giao', 'Đã hủy'],
        datasets: [{
            label: 'Số đơn hàng',
            data: [@Model.PendingOrders, 0, @(Model.TotalOrders - Model.PendingOrders), 0],
            backgroundColor: ['#fbbf24', '#60a5fa', '#34d399', '#f87171'],
            borderRadius: 8,
            borderSkipped: false,
        }]
    },
    options: {
        responsive: true,
        plugins: {
            legend: { display: false }
        },
        scales: {
            y: {
                beginAtZero: true,
                grid: { color: '#f3f4f6' },
                ticks: { stepSize: 1, font: { size: 11 } }
            },
            x: {
                grid: { display: false },
                ticks: { font: { size: 11 } }
            }
        }
    }
});
</script>
}
