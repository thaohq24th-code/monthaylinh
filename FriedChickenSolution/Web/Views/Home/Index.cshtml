@model List<ProductViewModel>
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Split Layout Hero Section -->
<div class="hero-split-section position-relative overflow-hidden" style="background-color: var(--primary-color);">
    <div class="container position-relative z-2">
        <div class="row align-items-center" style="min-height: 85vh;">
            <div class="col-lg-6 py-5 animate__animated animate__fadeInLeft text-white">
                <span class="badge bg-warning text-dark px-4 py-2 rounded-pill fs-6 mb-4 fw-bold" style="font-family: 'Oswald', sans-serif;">
                    <i class="fa-solid fa-fire-flame-curved me-2 text-danger"></i>Món Mới Cực Hot!
                </span>
                <h1 class="display-2 fw-black text-uppercase lh-1 mb-4" style="font-family: 'Oswald', sans-serif; text-shadow: 4px 4px 0px rgba(0,0,0,0.2);">
                    Gà Rán<br>Giòn Rụm<br><span class="text-warning">Chuẩn Vị</span>
                </h1>
                <p class="fs-4 mb-5 text-light opacity-75" style="max-width: 500px;">
                    Thưởng thức ngay miếng gà rán nóng hổi, vỏ ngoài giòn tan, thịt bên trong mọng nước cùng sốt độc quyền siêu đỉnh.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-warning btn-lg rounded-pill px-5 py-3 fw-bold text-uppercase shadow-lg d-flex align-items-center" style="font-family: 'Oswald', sans-serif; font-size: 1.2rem;">
                        <span>Đặt Món Ngay</span>
                        <i class="fa-solid fa-arrow-right ms-3 bg-white text-warning rounded-circle d-flex align-items-center justify-content-center" style="width: 30px; height: 30px;"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-6 position-relative d-none d-lg-block animate__animated animate__zoomIn">
                <!-- Decorative Circle -->
                <div class="position-absolute bg-warning rounded-circle" style="width: 600px; height: 600px; top: 50%; left: 50%; transform: translate(-40%, -50%); opacity: 0.2;"></div>
                <!-- Main Chicken Image -->
                <img src="https://images.unsplash.com/photo-1626082927389-6cd097cdc6ec?q=80&w=1000&auto=format&fit=crop" class="img-fluid rounded-4 shadow-2xl position-relative z-3" alt="Fried Chicken Bucket" style="transform: rotate(5deg); border: 15px solid white;">
                
                <!-- Floating Badge -->
                <div class="position-absolute bg-white p-4 rounded-4 shadow-lg z-3" style="bottom: 20px; left: -50px; transform: rotate(-10deg);">
                    <div class="d-flex align-items-center gap-3">
                        <div class="fs-1">🤤</div>
                        <div>
                            <div class="fw-bold text-dark fs-5 font-oswald text-uppercase">Giòn tan</div>
                            <div class="text-danger fw-bold">100% Gà Tươi</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Background pattern overlays -->
    <div class="position-absolute top-0 start-0 w-100 h-100" style="background-image: radial-gradient(rgba(255,255,255,0.1) 2px, transparent 2px); background-size: 30px 30px; z-index: 1;"></div>
</div>

<!-- Categories Pills -->
<div class="container mt-n5 position-relative z-3" style="margin-top: -30px;">
    <div class="bg-white rounded-pill shadow-lg p-3 d-flex justify-content-between flex-wrap gap-2 justify-content-md-center">
        <a href="#" class="btn btn-danger rounded-pill px-4 py-2 fw-bold d-flex align-items-center gap-2">
            <i class="fa-solid fa-drumstick-bite"></i> Gà Rán
        </a>
        <a href="#" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold d-flex align-items-center gap-2 border-0">
            <i class="fa-solid fa-burger"></i> Burger
        </a>
        <a href="#" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold d-flex align-items-center gap-2 border-0">
            <i class="fa-solid fa-pizza-slice"></i> Ăn Vặt
        </a>
        <a href="#" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold d-flex align-items-center gap-2 border-0">
            <i class="fa-solid fa-glass-water"></i> Đồ Uống
        </a>
    </div>
</div>

<!-- Products Section -->
@if (Model.Any())
{
    <div class="container py-5 my-5">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <span class="text-primary fw-bold text-uppercase" style="letter-spacing: 2px;">Menu Bán Chạy</span>
                <h2 class="display-5 fw-bold text-uppercase" style="font-family: 'Oswald', sans-serif;">Combo Giá Sốc</h2>
            </div>
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary rounded-pill fw-bold px-4">
                Xem toàn bộ Menu <i class="fa-solid fa-arrow-right ms-2"></i>
            </a>
        </div>
        
        <div class="row g-4 product-grid-fastfood">
            @await Html.PartialAsync("~/Views/Product/_ProductGridPartial.cshtml", Model)
        </div>
    </div>
}

<!-- Premium Asymmetric Call to Action Banner -->
<div class="container my-5">
    <div class="cta-premium-card p-5 overflow-hidden position-relative shadow-lg border-0" style="background: linear-gradient(135deg, #1f1412 0%, #0e0d0d 100%); border-radius: 30px; border: 1px solid rgba(255, 111, 0, 0.15) !important;">
        <!-- Glowing background light -->
        <div class="position-absolute top-50 start-100 translate-middle bg-warning rounded-circle opacity-10 blur-glow" style="width: 300px; height: 300px; filter: blur(80px); z-index: 1;"></div>
        
        <div class="row g-4 align-items-center position-relative" style="z-index: 2;">
            <div class="col-lg-8">
                <span class="badge bg-danger text-uppercase px-3 py-2 mb-3 fw-bold rounded-pill" style="letter-spacing: 1px;">🔥 Ưu Đãi Đặc Biệt</span>
                <h2 class="display-5 fw-black text-uppercase text-white mb-3" style="font-family: 'Oswald', sans-serif;">Giao Hàng Siêu Tốc Trong 30 Phút!</h2>
                <p class="fs-5 text-white-50 mb-0">Cam kết gà giòn nóng hổi, giao hàng tận nơi hoàn toàn miễn phí cho đơn hàng từ 150k. Gọi ngay hotline hoặc đặt món trực tuyến.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <div class="d-flex flex-column gap-3 align-items-lg-end">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-danger btn-lg rounded-pill px-5 py-4 fs-5 fw-bold text-uppercase shadow-lg btn-order-now transition-all">
                        Đặt Món Online <i class="fa-solid fa-circle-play ms-2"></i>
                    </a>
                    <span class="text-warning fs-5 fw-bold" style="font-family: 'Oswald', sans-serif;"><i class="fa-solid fa-phone-volume me-2"></i> Hotline: 1900 1234</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cta-premium-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .cta-premium-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(255, 111, 0, 0.1) !important;
    }
    .btn-order-now {
        background: linear-gradient(135deg, #d32f2f 0%, #ff6f00 100%) !important;
        border: none !important;
        box-shadow: 0 8px 25px rgba(211, 47, 47, 0.4) !important;
    }
    .btn-order-now:hover {
        transform: scale(1.05) !important;
        box-shadow: 0 12px 30px rgba(255, 111, 0, 0.6) !important;
    }
</style>
