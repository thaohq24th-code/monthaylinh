@{
    ViewData["Title"] = "Đã xảy ra lỗi";
}

<div class="container py-5 text-center">
    <div class="mb-4" style="font-size:4rem;">⚠️</div>
    <h1 class="section-title mb-3">Đã xảy ra lỗi</h1>
    <p class="text-muted mb-4">Rất xin lỗi, đã có lỗi xảy ra khi xử lý yêu cầu của bạn.</p>
    <p class="text-muted small mb-4">
        <strong>Request ID:</strong> <code>@ViewContext.HttpContext.TraceIdentifier</code>
    </p>
    <div class="d-flex gap-3 justify-content-center">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-5 py-2">
            <i class="fa-solid fa-house me-2"></i>Về trang chủ
        </a>
        <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4 py-2">
            <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
        </a>
    </div>
</div>
