<!-- Confirm Modal (dùng chung cho mọi hành động xóa/xác nhận trên toàn site) -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 rounded-modal shadow-2xl">
            <div class="modal-body p-5 text-center">
                <div class="confirm-icon-wrapper mb-4">
                    <i class="fa-solid fa-trash-can text-danger fs-1"></i>
                </div>
                <h5 class="fw-bold mb-3 font-serif" id="confirmMessage">Bạn có chắc chắn?</h5>
                <p class="text-muted small mb-4">Hành động này không thể hoàn tác.</p>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-light flex-grow-1 rounded-pill py-2" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" id="confirmActionBtn" class="btn btn-danger flex-grow-1 rounded-pill py-2">Xóa ngay</button>
                </div>
            </div>
        </div>
    </div>
</div>
