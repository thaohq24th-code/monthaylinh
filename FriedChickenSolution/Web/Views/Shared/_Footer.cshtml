@model Web.Models.SiteSettings
@{
    var settings = Model ?? new Web.Models.SiteSettings();
}
<!-- Premium Light-Cream Footer -->
<footer class="footer-premium-section position-relative" style="background-color: #f8f6f0; color: #4a3f35; border-top: 4px solid #d32f2f; box-shadow: inset 0 5px 15px rgba(0,0,0,0.02);">
    <div class="container pt-5 pb-4">
        <!-- Footer Top: Branding and Newsletter Box -->
        <div class="row g-4 align-items-center pb-5 mb-5" style="border-bottom: 1px solid #e8e3d5;">
            <div class="col-lg-6">
                <div class="d-flex align-items-center gap-3">
                    <div class="brand-logo-footer" style="background: linear-gradient(135deg, #d32f2f 0%, #ff6f00 100%); width: 50px; height: 50px; border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: white; box-shadow: 0 4px 10px rgba(211, 47, 47, 0.25);">
                        <i class="fa-solid fa-fire-flame-curved"></i>
                    </div>
                    <div>
                        <h3 class="brand-text-footer text-dark mb-0 text-uppercase fw-black" style="font-family: 'Oswald', sans-serif; letter-spacing: 1px; color: #2d241e !important;">@settings.SiteName</h3>
                        <p class="small text-muted mb-0">@settings.SiteTagline</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="bg-white p-3 rounded-pill d-flex align-items-center px-4 shadow-sm" style="border: 1px solid #e2dcd5;">
                    <i class="fa-solid fa-paper-plane text-danger me-3 fs-5"></i>
                    <span class="small text-muted d-none d-md-inline me-auto text-nowrap">Đăng ký nhận ưu đãi độc quyền:</span>
                    <div class="input-group ms-2" style="max-width: 320px;">
                        <input type="email" class="form-control form-control-sm bg-transparent border-0 text-dark shadow-none ps-0" placeholder="Nhập email của bạn..." style="font-size: 0.9rem;">
                        <button class="btn btn-danger btn-sm rounded-pill px-4 fw-bold text-uppercase ms-2 btn-footer-subscribe" type="button" style="font-size: 0.8rem;">Đăng ký</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Columns -->
        <div class="row g-5">
            <!-- Col 1: About & Socials -->
            <div class="col-lg-3 col-md-6">
                <h5 class="footer-heading-premium text-dark mb-4 text-uppercase fw-bold" style="font-family: 'Oswald', sans-serif; letter-spacing: 1px; color: #2d241e !important;">Kết nối với chúng tôi</h5>
                <p class="small text-muted mb-4">Theo dõi để cập nhật thực đơn mới nhất, các chương trình ưu đãi vàng và tin tức hấp dẫn hàng tuần.</p>
                <div class="social-links-premium d-flex gap-3">
                    <a href="@settings.SocialFacebook" target="_blank" class="social-icon-btn facebook"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="@settings.SocialInstagram" target="_blank" class="social-icon-btn instagram"><i class="fa-brands fa-instagram"></i></a>
                    <a href="@settings.SocialTiktok" target="_blank" class="social-icon-btn tiktok"><i class="fa-brands fa-tiktok"></i></a>
                </div>
            </div>
            
            <!-- Col 2: Policies & Guides -->
            <div class="col-lg-3 col-md-6">
                <h5 class="footer-heading-premium text-dark mb-4 text-uppercase fw-bold" style="font-family: 'Oswald', sans-serif; letter-spacing: 1px; color: #2d241e !important;">Chính sách & Hướng dẫn</h5>
                <ul class="list-unstyled footer-links-premium small">
                    <li class="mb-2"><a href="#" class="text-decoration-none text-muted transition-all"><i class="fa-solid fa-chevron-right me-2 text-danger fs-xsmall"></i> Chính sách giao hàng 24/7</a></li>
                    <li class="mb-2"><a href="#" class="text-decoration-none text-muted transition-all"><i class="fa-solid fa-chevron-right me-2 text-danger fs-xsmall"></i> Bảo mật thông tin khách hàng</a></li>
                    <li class="mb-2"><a href="#" class="text-decoration-none text-muted transition-all"><i class="fa-solid fa-chevron-right me-2 text-danger fs-xsmall"></i> Điều khoản sử dụng dịch vụ</a></li>
                    <li class="mb-2"><a href="#" class="text-decoration-none text-muted transition-all"><i class="fa-solid fa-chevron-right me-2 text-danger fs-xsmall"></i> Hướng dẫn thanh toán online</a></li>
                </ul>
            </div>
            
            <!-- Col 3: Store Locations -->
            <div class="col-lg-3 col-md-6">
                <h5 class="footer-heading-premium text-dark mb-4 text-uppercase fw-bold" style="font-family: 'Oswald', sans-serif; letter-spacing: 1px; color: #2d241e !important;">Hệ thống cửa hàng</h5>
                <ul class="list-unstyled footer-contact-premium small">
                    <li class="mb-3 d-flex align-items-start gap-2">
                        <i class="fa-solid fa-map-location-dot text-danger mt-1"></i>
                        <span><strong class="text-dark">CN Quận 1:</strong><br><span class="text-muted">@settings.FooterAddress</span></span>
                    </li>
                    <li class="mb-3 d-flex align-items-start gap-2">
                        <i class="fa-solid fa-map-location-dot text-danger mt-1"></i>
                        <span><strong class="text-dark">CN Tân Phú:</strong><br><span class="text-muted">456 Lũy Bán Bích, P. Hòa Thạnh, Q. Tân Phú, TP.HCM</span></span>
                    </li>
                </ul>
            </div>
            
            <!-- Col 4: Service Hours & Hotline -->
            <div class="col-lg-3 col-md-6">
                <h5 class="footer-heading-premium text-dark mb-4 text-uppercase fw-bold" style="font-family: 'Oswald', sans-serif; letter-spacing: 1px; color: #2d241e !important;">Thời gian phục vụ</h5>
                <ul class="list-unstyled footer-contact-premium small">
                    <li class="mb-3 d-flex align-items-start gap-2">
                        <i class="fa-solid fa-clock text-danger mt-1"></i>
                        <span><strong class="text-dark">Giờ mở cửa:</strong><br><span class="text-muted">08:30 - 22:30 hàng ngày (kể cả Lễ & Tết)</span></span>
                    </li>
                    <li class="mb-3 d-flex align-items-start gap-2">
                        <i class="fa-solid fa-phone-volume text-danger mt-1"></i>
                        <span><strong class="text-dark">Hotline hỗ trợ:</strong><br><span class="text-danger fw-bold fs-5">@settings.FooterPhone</span></span>
                    </li>
                    <li class="d-flex align-items-start gap-2">
                        <i class="fa-solid fa-envelope-open-text text-danger mt-1"></i>
                        <span><strong class="text-dark">Email liên hệ:</strong><br><span class="text-muted">@settings.FooterEmail</span></span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Footer Bottom -->
        <div class="footer-bottom-premium mt-5 pt-4 text-center small text-muted" style="border-top: 1px solid #e8e3d5;">
            <div class="row align-items-center">
                <div class="col-md-6 text-md-start mb-3 mb-md-0">
                    <p class="mb-0">© @DateTime.Now.Year <span class="text-dark fw-bold">@settings.SiteName</span>. Bảo lưu mọi quyền.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <span class="text-muted text-uppercase fw-bold" style="letter-spacing: 2px; font-size: 0.75rem; color: #a39589 !important;">Fast • Fresh • Crispy</span>
                </div>
            </div>
        </div>
    </div>
</footer>

<style>
    .footer-premium-section a.text-muted {
        color: #7a6e65 !important;
    }
    .footer-premium-section a.text-muted:hover {
        color: #d32f2f !important;
        padding-left: 5px;
    }
    .fs-xsmall {
        font-size: 0.65rem;
    }
    .social-icon-btn {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background-color: #ffffff;
        color: #4a3f35;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        transition: all 0.3s ease;
        text-decoration: none;
        border: 1px solid #e2dcd5;
        box-shadow: 0 2px 5px rgba(0,0,0,0.03);
    }
    .social-icon-btn:hover {
        transform: translateY(-3px);
        color: #ffffff !important;
        border-color: transparent;
    }
    .social-icon-btn.facebook:hover {
        background-color: #1877f2;
        box-shadow: 0 5px 15px rgba(24, 119, 242, 0.3);
    }
    .social-icon-btn.instagram:hover {
        background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
        box-shadow: 0 5px 15px rgba(220, 39, 67, 0.3);
    }
    .social-icon-btn.tiktok:hover {
        background-color: #010101;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
    }
    .btn-footer-subscribe {
        background: linear-gradient(135deg, #d32f2f 0%, #ff6f00 100%) !important;
        color: white !important;
        border: none !important;
        box-shadow: 0 2px 8px rgba(211, 47, 47, 0.2);
    }
    .btn-footer-subscribe:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(211, 47, 47, 0.4);
    }
</style>
