@model List<ArticleViewModel>
@using Web.Models
@using Web.Helpers
@inject Web.Helpers.SiteSettingsService SiteSettingsService
@{
    ViewData["Title"] = "Tin tức & Khuyến mãi";
    var settings = SiteSettingsService.GetSettings();
}

<!-- Article Hero Section -->
<div class="menu-hero-section py-5 mb-5 position-relative text-center overflow-hidden" style="background: linear-gradient(135deg, #fdfbf7 0%, #f5ebd9 100%); border-bottom: 1px solid #e5dec9;">
    <div class="position-absolute top-0 start-0 w-100 h-100 opacity-5" style="background-image: radial-gradient(#d32f2f 1px, transparent 1px); background-size: 20px 20px;"></div>
    
    <div class="container position-relative py-4" style="z-index: 2;">
        <span class="badge bg-danger text-uppercase px-3 py-2 mb-3 fw-bold rounded-pill" style="letter-spacing: 2px;">📢 Ưu Đãi & Sự Kiện</span>
        <h1 class="display-4 fw-black text-uppercase mb-3" style="font-family: 'Oswald', sans-serif; color: #2d241e; letter-spacing: 1px;">Tin Tức & Khuyến Mãi</h1>
        <p class="fs-5 text-muted mx-auto" style="max-width: 600px; line-height: 1.6;">Cập nhật nhanh nhất các chương trình giảm giá cực sâu, combo tặng kèm hấp dẫn và câu chuyện ẩm thực thú vị.</p>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4">
        @foreach (var a in Model)
        {
            <div class="col-lg-4 col-md-6 animate__animated animate__fadeInUp">
                <div class="blog-card h-100 shadow-sm" style="background: white; border-radius: 24px; border: 1px solid #e8e3d5; overflow: hidden; transition: all 0.3s; box-shadow: 0 4px 15px rgba(0,0,0,0.02) !important;">
                    <div class="position-relative" style="height: 220px; overflow: hidden; border-bottom: 1px solid rgba(226, 220, 213, 0.4);">
                        <img src="@(a.Image ?? "/images/no-image.png.svg")" class="w-100 h-100 blog-img" style="object-fit: cover; transition: transform 0.4s;" alt="@a.Title">
                        <span class="position-absolute badge bg-danger text-white px-3 py-2 fw-bold text-uppercase" style="top: 15px; left: 15px; border-radius: 50px; background: linear-gradient(135deg, #d32f2f 0%, #ff6f00 100%) !important; box-shadow: 0 4px 10px rgba(211, 47, 47, 0.2);">@a.Category</span>
                    </div>
                    <div class="card-body p-4 d-flex flex-column h-100">
                        <div class="text-muted small mb-2"><i class="fa-regular fa-calendar-check me-2 text-danger"></i>@a.CreatedDate.ToString("dd/MM/yyyy")</div>
                        <h5 class="fw-bold mb-3 font-oswald text-uppercase" style="font-family: 'Oswald', sans-serif; font-size: 1.2rem; line-height: 1.4; color: #2d241e;">
                            <a asp-controller="Article" asp-action="Detail" asp-route-id="@a.Id" class="text-decoration-none text-dark hover-primary" style="transition: color 0.2s;">@a.Title</a>
                        </h5>
                        <p class="text-muted small mb-4 line-clamp-2" style="font-size: 0.9rem; line-height: 1.6;">@a.Summary</p>
                        
                        <div class="mt-auto">
                            <a asp-controller="Article" asp-action="Detail" asp-route-id="@a.Id" class="btn btn-premium-action rounded-pill fw-bold text-uppercase px-4 py-2-5" style="font-family: 'Oswald', sans-serif; font-size: 0.8rem; letter-spacing: 0.5px;">
                                Xem Chi Tiết <i class="fa-solid fa-arrow-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="fa-solid fa-receipt opacity-25 mb-3" style="font-size: 3rem;"></i>
            <p>Chưa có bài viết hay tin tức khuyến mãi nào.</p>
        </div>
    }
</div>

<style>
    .blog-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(211, 47, 47, 0.1) !important;
        border-color: #d32f2f !important;
    }
    .blog-card:hover .blog-img {
        transform: scale(1.05);
    }
    .btn-premium-action {
        background: linear-gradient(135deg, #d32f2f 0%, #ff6f00 100%) !important;
        color: white !important;
        border: none !important;
        box-shadow: 0 4px 12px rgba(211, 47, 47, 0.2);
        transition: all 0.3s ease;
    }
    .btn-premium-action:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(255, 111, 0, 0.4);
    }
    .py-2-5 {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }
</style>
