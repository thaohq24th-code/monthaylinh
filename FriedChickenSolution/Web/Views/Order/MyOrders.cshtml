@model List<OrderViewModel>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container py-5">
    <div class="mb-5">
        <h2 class="section-title mb-3">Lịch sử đơn hàng</h2>
        <p class="text-muted">Theo dõi trạng thái và chi tiết các đơn hàng của bạn</p>
    </div>

    <div id="my-orders-container">
        @await Html.PartialAsync("_MyOrdersPartial", Model)
    </div>
</div>

@section Scripts {
    <script>
        window.orderRoutes = {
            myOrdersPartial: '@Url.Action("MyOrdersPartial", "Order")'
        };
    </script>
}
