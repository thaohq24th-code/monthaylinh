@model List<FeedbackViewModel>

@if (Model.Any())
{
    <div class="feedback-history-container">
        @foreach (var f in Model)
        {
            <div class="admin-card p-4 mb-3 animate__animated animate__fadeInUp">
                <div class="mb-3 pb-3 border-bottom">
                    <div class="d-flex justify-content-between align-items-start">
                        <h6 class="fw-bold mb-2">@f.Title</h6>
                        <span class="small text-muted"><i class="fa-regular fa-calendar me-1"></i>@f.CreatedDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <p class="text-dark small mb-0" style="white-space: pre-line;">@f.Content</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(f.AdminReply))
                {
                    <div class="bg-primary-light p-3 rounded-3 mb-0">
                        <p class="small text-muted mb-2"><i class="fa-solid fa-reply me-1"></i>Phản hồi từ admin <span class="text-muted">@f.ReplyDate?.ToString("dd/MM/yyyy")</span></p>
                        <p class="text-dark small mb-0" style="white-space: pre-line;">@f.AdminReply</p>
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-0 fst-italic">Admin sẽ trả lời sớm nhất...</p>
                }
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5 text-muted">
        <i class="fa-solid fa-envelope-open-text opacity-25 mb-3" style="font-size: 2rem;"></i>
        <p class="small">Bạn chưa gửi phản hồi nào.</p>
    </div>
}
