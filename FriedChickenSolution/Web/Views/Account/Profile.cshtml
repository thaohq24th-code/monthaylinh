@model ProfileViewModel
@{
    ViewData["Title"] = "Thông tin tài khoản";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="admin-card p-5 rounded-4">
                <!-- Avatar Section -->
                <div class="text-center mb-5">
                    <div class="position-relative d-inline-block">
                        <div id="avatarContainer" style="width:100px;height:100px;border-radius:50%;overflow:hidden;border:3px solid var(--primary-color,#8b5e3c);margin:0 auto;">
                            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                            {
                                <img id="avatarImg" src="@Model.AvatarUrl" alt="Avatar"
                                     style="width:100%;height:100%;object-fit:cover;"
                                     onerror="this.src='/images/no-image.png.svg'">
                            }
                            else
                            {
                                <div id="avatarDefault" style="width:100%;height:100%;background:var(--primary-color,#8b5e3c);display:flex;align-items:center;justify-content:center;color:white;font-size:2.5rem;font-weight:700;">
                                    @{
                                        var profileInitial = !string.IsNullOrEmpty(Model.FullName) ? Model.FullName[0]
                                            : !string.IsNullOrEmpty(Model.Username) ? Model.Username[0] : '?';
                                    }
                                    @profileInitial
                                </div>
                            }
                        </div>
                        <!-- Camera button to change avatar -->
                        <label for="avatarInput" class="position-absolute" style="bottom:0;right:0;width:30px;height:30px;border-radius:50%;background:var(--primary-color,#8b5e3c);border:2px solid white;display:flex;align-items:center;justify-content:center;cursor:pointer;color:white;">
                            <i class="fa-solid fa-camera" style="font-size:0.7rem;"></i>
                        </label>
                    </div>
                    <h5 class="mt-3 fw-bold mb-0">@(Model.FullName ?? Model.Username)</h5>
                    <small class="text-muted">@@Model.Username</small>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success rounded-4 border-0 small mb-4">@TempData["SuccessMessage"]</div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger rounded-4 border-0 small mb-4">@TempData["ErrorMessage"]</div>
                }

                <!-- Avatar Upload Form (hidden) -->
                <form id="avatarForm" asp-controller="Account" asp-action="UploadAvatar" method="post" enctype="multipart/form-data" style="display:none;">
                    @Html.AntiForgeryToken()
                    <input type="file" id="avatarInput" name="avatarFile" accept="image/*" onchange="uploadAvatar(this)">
                </form>

                <!-- Profile Form -->
                <form asp-controller="Account" asp-action="Profile" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 border-0 small" style="display: @(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-uppercase tracking-wider">Tên đăng nhập</label>
                        <input type="text" class="form-control auth-input" value="@Model.Username" disabled>
                    </div>

                    <div class="mb-4">
                        <label asp-for="FullName" class="form-label small fw-bold text-uppercase tracking-wider"></label>
                        <input asp-for="FullName" class="form-control auth-input" placeholder="Nhập họ tên đầy đủ">
                    </div>

                    <div class="mb-4">
                        <label asp-for="Phone" class="form-label small fw-bold text-uppercase tracking-wider"></label>
                        <input asp-for="Phone" class="form-control auth-input" placeholder="Số điện thoại">
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="mb-5">
                        <label asp-for="Email" class="form-label small fw-bold text-uppercase tracking-wider"></label>
                        <input asp-for="Email" class="form-control auth-input" placeholder="Email">
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Cập nhật thông tin
                    </button>
                </form>

                <hr class="my-5 opacity-25">

                <div class="row g-3">
                    <div class="col-6">
                        <div class="alert alert-info rounded-4 border-0 small mb-0 text-center">
                            <i class="fa-solid fa-user-shield me-1"></i>
                            @(Model.Role == "Admin" ? "Quản trị viên" : "Khách hàng")
                        </div>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Order" asp-action="MyOrders" class="btn btn-outline-dark w-100 py-2 rounded-pill fw-bold small">
                            <i class="fa-solid fa-bag-shopping me-2"></i>Đơn hàng của tôi
                        </a>
                    </div>
                </div>

                <div class="mt-3">
                    <a asp-controller="Post" asp-action="Index" class="btn btn-outline-primary w-100 py-2 rounded-pill fw-bold small">
                        <i class="fa-solid fa-newspaper me-2"></i>Bài viết cộng đồng
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
async function uploadAvatar(input) {
    if (!input.files || !input.files[0]) return;

    // Preview ngay lập tức
    const reader = new FileReader();
    reader.onload = e => {
        const container = document.getElementById('avatarContainer');
        container.innerHTML = `<img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;">`;
    };
    reader.readAsDataURL(input.files[0]);

    // Submit form
    document.getElementById('avatarForm').submit();
}
</script>
}
