@model List<Core.Database.Models.Post>
@{
    ViewData["Title"] = "Cộng đồng - Bài viết";
    int totalPages = (int)(ViewBag.TotalPages ?? 1);
    int currentPage = (int)(ViewBag.CurrentPage ?? 1);
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="section-title mb-1">📝 Bài viết cộng đồng</h2>
            <p class="text-muted">Chia sẻ trải nghiệm và kết nối với cộng đồng</p>
        </div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Post" asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="fa-solid fa-pen-to-square me-2"></i>Đăng bài mới
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary rounded-pill px-4">
                <i class="fa-solid fa-right-to-bracket me-2"></i>Đăng nhập để đăng bài
            </a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 rounded-4 mb-4">@TempData["SuccessMessage"]</div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="fa-solid fa-newspaper opacity-25 mb-3" style="font-size:3rem;"></i>
            <p>Chưa có bài viết nào. Hãy là người đầu tiên chia sẻ!</p>
        </div>
    }

    <div class="row g-4">
        @foreach (var post in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="admin-card h-100 overflow-hidden" style="border-radius:1rem;transition:transform 0.2s;cursor:pointer;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform=''">
                    @if (!string.IsNullOrEmpty(post.ImageUrl))
                    {
                        <img src="@post.ImageUrl" alt="@post.Title" style="width:100%;height:180px;object-fit:cover;">
                    }
                    else
                    {
                        <div style="width:100%;height:100px;background:linear-gradient(135deg,#8b5e3c22,#d9770622);display:flex;align-items:center;justify-content:center;">
                            <i class="fa-solid fa-pen-to-square" style="font-size:2rem;color:#8b5e3c;opacity:0.4;"></i>
                        </div>
                    }
                    <div class="p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            @if (!string.IsNullOrEmpty(post.User?.AvatarUrl))
                            {
                                <img src="@post.User.AvatarUrl" style="width:32px;height:32px;border-radius:50%;object-fit:cover;">
                            }
                            else
                            {
                                <div style="width:32px;height:32px;border-radius:50%;background:#8b5e3c;display:flex;align-items:center;justify-content:center;color:white;font-size:0.75rem;font-weight:700;">
                                    @{
                                        var postInitial = !string.IsNullOrEmpty(post.User?.FullName) ? post.User.FullName[0]
                                            : !string.IsNullOrEmpty(post.User?.Username) ? post.User.Username[0] : '?';
                                    }
                                    @postInitial
                                </div>
                            }
                            <div>
                                <div class="fw-semibold small">@(post.User?.FullName ?? post.User?.Username ?? "Ẩn danh")</div>
                                <div class="text-muted" style="font-size:0.72rem;">@post.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        </div>
                        <h5 class="fw-bold mb-2" style="font-size:1rem;line-height:1.4;">
                            <a asp-controller="Post" asp-action="Detail" asp-route-id="@post.Id" class="text-decoration-none text-dark stretched-link">@post.Title</a>
                        </h5>
                        <p class="text-muted small mb-3" style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;">
                            @post.Content
                        </p>
                        <div class="d-flex align-items-center gap-3 text-muted small">
                            <span><i class="fa-regular fa-comment me-1"></i>@post.Comments.Count bình luận</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <div class="d-flex justify-content-center gap-2 mt-5">
            @for (int i = 1; i <= totalPages; i++)
            {
                <a asp-action="Index" asp-route-page="@i"
                   class="btn @(i == currentPage ? "btn-primary" : "btn-outline-secondary") rounded-circle"
                   style="width:40px;height:40px;padding:0;line-height:38px;text-align:center;">@i</a>
            }
        </div>
    }
</div>
